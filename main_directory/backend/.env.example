# Environment configuration template for MACHARIA'S FARMHOUSE

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=password

# Session secret
SESSION_SECRET=your-secret-key-change-in-production

# MySQL configuration (for local development)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=example
MYSQL_DATABASE=mf_db

# OpenAI configuration (optional, for LLM-powered chatbot)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Analytics URL (for docker-compose, use http://analytics:5001)
ANALYTICS_URL=http://localhost:5001

# Backend URL (used by analytics service to verify internal routes)
BACKEND_URL=http://localhost:3000

# Optional: Tableau dashboard URL for embedded analysis in admin chatbot
# Example: https://public.tableau.com/views/YourWorkbook/YourDashboard?:showVizHome=no&:embed=y
VITE_TABLEAU_URL=

# Node environment
NODE_ENV=production
PORT=3000
